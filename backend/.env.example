PORT=4000
# MongoDB connection string (Atlas or local). Put the database name in the
# path — e.g. mongodb+srv://user:pass@cluster.mongodb.net/virtual-office
# Leave unset to run without persistence (in-memory only).
MONGODB_URI=mongodb://localhost:27017/virtual-office
# Electricity tariff used for the room report's cost estimate.
COST_PER_KWH=8.5
CURRENCY=৳
